# Terraform provider binaries and local state
.terraform/
*.tfstate
*.tfstate.backup

# Fetched cluster kubeconfig (holds admin credentials)
kubeconfig

# Terraform variables (often hold secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*.tfplan

# Python
__pycache__/
*.pyc
.venv/
venv/
env/

# Generic env files
.env
.env.local

# macOS
.DS_Store
